# ── Raw Data (Kaggle files are large — never push these) ──────
data/raw/
*.csv
*.xlsx
*.zip
*.tar.gz

# ── Processed data (regenerated by running notebooks) ────────
data/processed/

# ── Jupyter Notebook artifacts ────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables (API keys, credentials) ─────────────
.env
.env.local
*.env

# ── OS generated files ────────────────────────────────────────
.DS_Store           # Mac
Thumbs.db           # Windows
desktop.ini         # Windows

# ── IDE / Editor files ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Model files (can be large — regenerate by running code) ───
*.pkl
*.pickle
*.joblib
*.h5

# ── Prophet / Statsmodels temp files ──────────────────────────
/tmp/
cmdstanpy/

# ── Reports (keep figures, skip heavy exports) ────────────────
reports/*.pdf
reports/*.html